<UserControl x:Class="CarShell.Pages.Settings.AboutSettingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <UserControl.Resources>

        <Style x:Key="SettingsCardStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="#101820"/>
            <Setter Property="BorderBrush"
                    Value="#1B2A38"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="18"/>
            <Setter Property="Padding"
                    Value="24"/>
            <Setter Property="Margin"
                    Value="0,0,0,16"/>
        </Style>

        <Style x:Key="RightPanelScrollStyle"
               TargetType="ScrollViewer">
            <Setter Property="VerticalScrollBarVisibility"
                    Value="Hidden"/>
            <Setter Property="HorizontalScrollBarVisibility"
                    Value="Disabled"/>
            <Setter Property="PanningMode"
                    Value="VerticalOnly"/>
            <Setter Property="PanningDeceleration"
                    Value="0.0015"/>
            <Setter Property="PanningRatio"
                    Value="1.1"/>
            <Setter Property="CanContentScroll"
                    Value="False"/>
            <Setter Property="IsManipulationEnabled"
                    Value="True"/>
            <Setter Property="Focusable"
                    Value="False"/>
            <EventSetter Event="ManipulationBoundaryFeedback"
                         Handler="ScrollViewer_ManipulationBoundaryFeedback"/>
        </Style>

    </UserControl.Resources>

    <ScrollViewer Style="{StaticResource RightPanelScrollStyle}">

        <StackPanel Margin="0,0,0,100"
                    Background="Transparent">

            <TextBlock Text="О программе"
                       FontSize="32"
                       FontWeight="Bold"
                       Foreground="White"/>

            <TextBlock Text="Информация о CarShell"
                       FontSize="17"
                       Foreground="#778A9E"
                       Margin="0,5,0,24"/>

            <Border Style="{StaticResource SettingsCardStyle}">
                <StackPanel>
                    <TextBlock Text="CarShell"
                               FontSize="31"
                               FontWeight="Bold"
                               Foreground="White"/>

                    <TextBlock Text="Автомобильная мультимедийная система"
                               FontSize="17"
                               Foreground="#8295A8"
                               Margin="0,8,0,0"/>

                    <TextBlock x:Name="AboutVersionText"
                               Text="Версия неизвестна"
                               FontSize="16"
                               Foreground="#4CA9DD"
                               Margin="0,22,0,0"/>

                    <TextBlock Text="Платформа: Windows 10 IoT Enterprise LTSC 2021"
                               FontSize="15"
                               Foreground="#8295A8"
                               Margin="0,7,0,0"/>

                    <TextBlock Text="Интерфейс: .NET 8 WPF"
                               FontSize="15"
                               Foreground="#8295A8"
                               Margin="0,7,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>

    </ScrollViewer>

</UserControl>
