<Page x:Class="CarShell.Pages.Settings.UpdateSettingsControl"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      mc:Ignorable="d"
      d:DesignHeight="720"
      d:DesignWidth="1000"
      Title="Обновления"
      Background="#05080D">

    <Page.Resources>

        <!-- Основная кнопка -->
        <Style x:Key="UpdateActionButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="52"/>

            <Setter Property="MinWidth"
                    Value="160"/>

            <Setter Property="Padding"
                    Value="22,0"/>

            <Setter Property="Margin"
                    Value="0,0,12,12"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#1B6CA8"/>

            <Setter Property="BorderBrush"
                    Value="#2888C8"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="FontSize"
                    Value="18"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#2486C7"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#14527D"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#27313A"/>

                                <Setter TargetName="ButtonBorder"
                                        Property="BorderBrush"
                                        Value="#35424D"/>

                                <Setter Property="Foreground"
                                        Value="#697785"/>

                                <Setter Property="Cursor"
                                        Value="Arrow"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- Вторичная кнопка -->
        <Style x:Key="UpdateSecondaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource UpdateActionButtonStyle}">

            <Setter Property="Background"
                    Value="#202B35"/>

            <Setter Property="BorderBrush"
                    Value="#344655"/>

        </Style>

        <!-- Кнопка выбранной версии -->
        <Style x:Key="RollbackButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource UpdateActionButtonStyle}">

            <Setter Property="Background"
                    Value="#6E3038"/>

            <Setter Property="BorderBrush"
                    Value="#95444F"/>

        </Style>

        <!-- Карточка -->
        <Style x:Key="UpdateCardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="#101820"/>

            <Setter Property="BorderBrush"
                    Value="#1B2A38"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="CornerRadius"
                    Value="18"/>

            <Setter Property="Padding"
                    Value="24"/>

            <Setter Property="Margin"
                    Value="0,0,0,16"/>

        </Style>

        <!-- ComboBox -->
        <Style x:Key="VersionComboBoxStyle"
               TargetType="ComboBox">

            <Setter Property="Height"
                    Value="54"/>

            <Setter Property="Padding"
                    Value="15,0"/>

            <Setter Property="FontSize"
                    Value="18"/>

            <Setter Property="Foreground"
                    Value="Black"/>

            <Setter Property="Background"
                    Value="White"/>

            <Setter Property="BorderBrush"
                    Value="#344655"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>

        </Style>

    </Page.Resources>

    <Grid>

        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">

            <StackPanel>

                <!-- Заголовок -->
                <TextBlock Text="Обновления"
                           FontSize="32"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Проверка обновлений и установка предыдущих версий CarShell"
                           FontSize="17"
                           Foreground="#778A9E"
                           Margin="0,5,0,24"/>

                <!-- Текущая версия -->
                <Border Style="{StaticResource UpdateCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Текущая версия"
                                   FontSize="17"
                                   Foreground="#8295A8"/>

                        <TextBlock x:Name="CurrentVersionText"
                                   Text="Текущая версия: неизвестно"
                                   Margin="0,6,0,0"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                    </StackPanel>

                </Border>

                <!-- Последнее обновление -->
                <Border Style="{StaticResource UpdateCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Последняя версия"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <TextBlock x:Name="LatestVersionText"
                                   Text="Последняя версия: неизвестно"
                                   Margin="0,8,0,0"
                                   FontSize="18"
                                   Foreground="#B8C5D2"/>

                        <TextBlock Text="Проверка выполняется через GitHub Releases"
                                   Margin="0,7,0,20"
                                   FontSize="15"
                                   Foreground="#778A9E"/>

                        <WrapPanel>

                            <Button x:Name="CheckButton"
                                    Content="Проверить"
                                    Style="{StaticResource UpdateActionButtonStyle}"
                                    Click="CheckUpdate_Click"/>

                            <Button x:Name="DownloadButton"
                                    Content="Скачать"
                                    Style="{StaticResource UpdateSecondaryButtonStyle}"
                                    IsEnabled="False"
                                    Click="DownloadUpdate_Click"/>

                            <Button x:Name="InstallButton"
                                    Content="Установить"
                                    Style="{StaticResource UpdateActionButtonStyle}"
                                    IsEnabled="False"
                                    Click="InstallUpdate_Click"/>

                        </WrapPanel>

                    </StackPanel>

                </Border>

                <!-- Выбор версии -->
                <Border Style="{StaticResource UpdateCardStyle}">

                    <StackPanel>

                        <TextBlock Text="История версий"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <TextBlock Text="Выберите опубликованную версию для обновления или отката"
                                   Margin="0,7,0,20"
                                   FontSize="15"
                                   Foreground="#778A9E"/>

                        <Grid Margin="0,0,0,16">

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <ComboBox x:Name="VersionsComboBox"
                                      Grid.Column="0"
                                      Margin="0,0,12,0"
                                      Style="{StaticResource VersionComboBoxStyle}"
                                      SelectionChanged="VersionsComboBox_SelectionChanged"/>

                            <Button x:Name="RefreshVersionsButton"
                                    Grid.Column="1"
                                    Content="Обновить список"
                                    Style="{StaticResource UpdateSecondaryButtonStyle}"
                                    Margin="0"
                                    Click="RefreshVersions_Click"/>

                        </Grid>

                        <TextBlock x:Name="SelectedVersionText"
                                   Text="Выбранная версия: не выбрана"
                                   FontSize="18"
                                   Foreground="#B8C5D2"
                                   Margin="0,0,0,16"/>

                        <Button x:Name="RollbackButton"
                                Content="Скачать выбранную версию"
                                HorizontalAlignment="Left"
                                Style="{StaticResource RollbackButtonStyle}"
                                IsEnabled="False"
                                Click="Rollback_Click"/>

                    </StackPanel>

                </Border>

                <!-- Состояние -->
                <Border Style="{StaticResource UpdateCardStyle}">

                    <StackPanel>

                        <TextBlock Text="Состояние"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="White"/>

                        <TextBlock x:Name="StatusText"
                                   Text="Нажмите «Проверить»"
                                   Margin="0,10,0,18"
                                   FontSize="19"
                                   FontWeight="SemiBold"
                                   Foreground="#E0E8F0"
                                   TextWrapping="Wrap"/>

                        <TextBlock Text="Описание версии"
                                   FontSize="17"
                                   FontWeight="SemiBold"
                                   Foreground="#8FA0B2"
                                   Margin="0,0,0,8"/>

                        <Border Background="#090E13"
                                BorderBrush="#202E3A"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="18"
                                MinHeight="120">

                            <TextBlock x:Name="NotesText"
                                       Text="Описание обновления появится здесь."
                                       FontSize="16"
                                       LineHeight="24"
                                       Foreground="#B5C1CF"
                                       TextWrapping="Wrap"/>

                        </Border>

                    </StackPanel>

                </Border>

            </StackPanel>

        </ScrollViewer>

    </Grid>

</Page>