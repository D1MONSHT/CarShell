<UserControl x:Class="CarShell.Pages.HomePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#05080D">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background" Value="#101923"/>
            <Setter Property="BorderBrush" Value="#27384A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="26"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="24"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="34">
        <Grid.RowDefinitions>
            <RowDefinition Height="90"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя строка без заголовка -->
        <Grid Grid.Row="0">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <TextBlock x:Name="ClockText"
                           Text="--:--"
                           FontSize="52"
                           FontWeight="Bold"
                           Foreground="White"
                           Margin="0,0,30,0"/>

                <TextBlock Text="●"
                           FontSize="24"
                           Foreground="#35D07F"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>

                <TextBlock Text="ONL"
                           FontSize="20"
                           Foreground="#718196"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Grid>

        <!-- Основная панель -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
            </Grid.ColumnDefinitions>

            <!-- Скорость -->
            <Border Style="{StaticResource Card}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center">

                    <TextBlock x:Name="SpeedText"
                               Text="0"
                               FontSize="150"
                               FontWeight="Bold"
                               Foreground="#00C8FF"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="km/h"
                               FontSize="28"
                               Foreground="#718196"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Малые карточки -->
            <UniformGrid Grid.Column="1" Rows="2" Columns="2">

                <Border Style="{StaticResource Card}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="RPM"
                                   FontSize="18"
                                   Foreground="#718196"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="RpmText"
                                   Text="850"
                                   FontSize="52"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="ENGINE TEMP"
                                   FontSize="18"
                                   Foreground="#718196"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="TempText"
                                   Text="82°C"
                                   FontSize="52"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="BOOST"
                                   FontSize="18"
                                   Foreground="#718196"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="BoostText"
                                   Text="0.15 bar"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="BATTERY"
                                   FontSize="18"
                                   Foreground="#718196"
                                   HorizontalAlignment="Center"/>

                        <TextBlock x:Name="VoltageText"
                                   Text="14.1 V"
                                   FontSize="48"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

            </UniformGrid>
        </Grid>

        <!-- Нижняя строка -->
       
    </Grid>
</UserControl>