<UserControl x:Class="CarShell.Pages.DiagnosticsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#05070A">

    <UserControl.Resources>
        <Style x:Key="HeaderText" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="21"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="StatusCard" TargetType="Border">
            <Setter Property="Background" Value="#0B0F14"/>
            <Setter Property="BorderBrush" Value="#252B33"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="Margin" Value="0,0,8,8"/>
        </Style>

        <Style x:Key="ErrorCard" TargetType="Border">
            <Setter Property="Background" Value="#1A0A0D"/>
            <Setter Property="BorderBrush" Value="#7F2E35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="WarningCard" TargetType="Border">
            <Setter Property="Background" Value="#1A1408"/>
            <Setter Property="BorderBrush" Value="#7F6E35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="SuccessCard" TargetType="Border">
            <Setter Property="Background" Value="#0D1A0D"/>
            <Setter Property="BorderBrush" Value="#2E7F35"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="StatusLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#C5CBD2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="TextTrimming" Value="CharacterEllipsis"/>
        </Style>

        <Style x:Key="StatusValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="0,4,0,0"/>
        </Style>

        <Style x:Key="ErrorCode" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#FF5B61"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Consolas"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="ErrorDescription" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E0E4E8"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="12,7,12,9">
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid>
            <TextBlock Text="Диагностика" Style="{StaticResource HeaderText}"/>
            <TextBlock x:Name="ClockText" Text="16:20" Foreground="White"
                       FontSize="23" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusIndicatorText" Text="ВСЕ СИСТЕМЫ OK"
                       Foreground="#69D66D" FontSize="14" FontWeight="SemiBold"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,8,0,0">
            <StackPanel>
                <!-- Системы здоровья -->
                <TextBlock Text="Статус систем" Foreground="#C5CBD2" FontSize="13"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>

                <UniformGrid Columns="2" Rows="2" Margin="0,0,0,12">
                    <Border Style="{StaticResource StatusCard}">
                        <StackPanel>
                            <TextBlock Text="Двигатель" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="EngineStatusText" Text="НОРМА"
                                       Style="{StaticResource StatusValue}" Foreground="#69D66D"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusCard}">
                        <StackPanel>
                            <TextBlock Text="Трансмиссия" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="TransmissionStatusText" Text="НОРМА"
                                       Style="{StaticResource StatusValue}" Foreground="#69D66D"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusCard}">
                        <StackPanel>
                            <TextBlock Text="Выхлопная система" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="EmissionStatusText" Text="НОРМА"
                                       Style="{StaticResource StatusValue}" Foreground="#69D66D"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource StatusCard}">
                        <StackPanel>
                            <TextBlock Text="Тормозная система" Style="{StaticResource StatusLabel}"/>
                            <TextBlock x:Name="BrakeStatusText" Text="НОРМА"
                                       Style="{StaticResource StatusValue}" Foreground="#69D66D"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Активные ошибки -->
                <TextBlock Text="Активные ошибки" Foreground="#C5CBD2" FontSize="13"
                           FontWeight="SemiBold" Margin="0,0,0,8"/>

                <StackPanel x:Name="ErrorsPanel">
                    <Border Style="{StaticResource SuccessCard}">
                        <StackPanel>
                            <TextBlock Text="✓ Ошибок не обнаружено" 
                                       Foreground="#69D66D" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Предупреждения -->
                <TextBlock Text="Предупреждения" Foreground="#C5CBD2" FontSize="13"
                           FontWeight="SemiBold" Margin="0,12,0,8"/>

                <StackPanel x:Name="WarningsPanel">
                    <Border Style="{StaticResource SuccessCard}">
                        <StackPanel>
                            <TextBlock Text="✓ Предупреждений нет" 
                                       Foreground="#69D66D" FontSize="12" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- История -->
                <TextBlock Text="История ошибок" Foreground="#C5CBD2" FontSize="13"
                           FontWeight="SemiBold" Margin="0,12,0,8"/>

                <StackPanel x:Name="HistoryPanel">
                    <Border Style="{StaticResource SuccessCard}">
                        <StackPanel>
                            <TextBlock Text="История пуста" 
                                       Foreground="#929BA5" FontSize="12"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <TextBlock Margin="0,20,0,0"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
