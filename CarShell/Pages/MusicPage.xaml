<UserControl x:Class="CarShell.Pages.MusicPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#05080D">

    <UserControl.Resources>
        <Style x:Key="TabButton" TargetType="Button">
            <Setter Property="Height" Value="64"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontSize" Value="24"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#101923"/>
            <Setter Property="BorderBrush" Value="#27384A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="22"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RadioButtonStyle" TargetType="Button" BasedOn="{StaticResource TabButton}">
            <Setter Property="Height" Value="110"/>
            <Setter Property="FontSize" Value="28"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="86"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхние вкладки -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BtnYoutubeMusic"
                    Grid.Column="0"
                    Content="YouTube Music"
                    Click="YouTubeMusic_Click"
                    Style="{StaticResource TabButton}"/>

            <Button x:Name="BtnRadioPlayer"
                    Grid.Column="1"
                    Content="Radio Player"
                    Click="RadioPlayer_Click"
                    Style="{StaticResource TabButton}"/>

            <Button x:Name="BtnCarRadio"
                    Grid.Column="2"
                    Content="Радио магнитолы"
                    Click="CarRadio_Click"
                    Style="{StaticResource TabButton}"/>
        </Grid>

        <!-- Контент -->
        <Grid Grid.Row="1">

            <!-- YouTube Music -->
            <Border x:Name="YoutubeMusicPanel"
                    CornerRadius="24"
                    Background="#101923"
                    BorderBrush="#27384A"
                    BorderThickness="2"
                    Padding="6">

                <wv2:WebView2 x:Name="MusicWebView"/>
            </Border>

            <!-- Radio Player -->
            <Grid x:Name="RadioPlayerPanel"
                  Visibility="Collapsed">

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="110"/>
                </Grid.RowDefinitions>

                <UniformGrid Rows="2" Columns="3">
                    <Button Content="RMF FM" Style="{StaticResource RadioButtonStyle}"/>
                    <Button Content="Radio ZET" Style="{StaticResource RadioButtonStyle}"/>
                    <Button Content="Eska" Style="{StaticResource RadioButtonStyle}"/>
                    <Button Content="Antyradio" Style="{StaticResource RadioButtonStyle}"/>
                    <Button Content="Tok FM" Style="{StaticResource RadioButtonStyle}"/>
                    <Button Content="Open FM" Style="{StaticResource RadioButtonStyle}"/>
                </UniformGrid>

                <Border Grid.Row="1"
                        Background="#101923"
                        BorderBrush="#27384A"
                        BorderThickness="2"
                        CornerRadius="24"
                        Margin="8"
                        Padding="18">
                    <Grid>
                        <TextBlock Text="Radio Player"
                                   FontSize="28"
                                   Foreground="White"
                                   VerticalAlignment="Center"/>

                        <StackPanel Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <Button Content="⏮" Width="80" Height="56" FontSize="28" Margin="8"/>
                            <Button Content="⏯" Width="80" Height="56" FontSize="28" Margin="8"/>
                            <Button Content="⏭" Width="80" Height="56" FontSize="28" Margin="8"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Радио магнитолы -->
            <Grid x:Name="CarRadioPanel"
                  Visibility="Collapsed">

                <Border Background="#101923"
                        BorderBrush="#27384A"
                        BorderThickness="2"
                        CornerRadius="28"
                        Padding="40">

                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="120"/>
                        </Grid.RowDefinitions>

                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center">
                            <TextBlock Text="FM RADIO"
                                       FontSize="32"
                                       Foreground="#718196"
                                       HorizontalAlignment="Center"/>

                            <TextBlock x:Name="FrequencyText"
                                       Text="87.5"
                                       FontSize="120"
                                       FontWeight="Bold"
                                       Foreground="#35D07F"
                                       HorizontalAlignment="Center"/>

                            <TextBlock Text="MHz"
                                       FontSize="30"
                                       Foreground="White"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>

                        <UniformGrid Grid.Row="1"
                                     Rows="1"
                                     Columns="5">
                            <Button Content="◀" FontSize="34" Margin="10"/>
                            <Button Content="SCAN-" FontSize="24" Margin="10"/>
                            <Button Content="MUTE" FontSize="24" Margin="10"/>
                            <Button Content="SCAN+" FontSize="24" Margin="10"/>
                            <Button Content="▶" FontSize="34" Margin="10"/>
                        </UniformGrid>
                    </Grid>
                </Border>
            </Grid>

        </Grid>
    </Grid>
</UserControl>