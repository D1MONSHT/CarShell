<UserControl x:Class="CarShell.Pages.NavigationPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
             Background="#05080D">

    <UserControl.Resources>
        <Style x:Key="NavButton" TargetType="Button">
            <Setter Property="Height" Value="54"/>
            <Setter Property="Margin" Value="6"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#101923"/>
            <Setter Property="BorderBrush" Value="#27384A"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="18"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="0"/>
            <RowDefinition Height="74"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">

            <TextBlock x:Name="GpsStatusText"
                       Text="GPS: DEMO"
                       FontSize="24"
                       Foreground="#FF9800"
                       HorizontalAlignment="Right"
                       VerticalAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="180"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="SearchBox"
                     FontSize="22"
                     Margin="0,8,10,8"
                     Padding="18,0"
                     VerticalContentAlignment="Center"
                     Text=""
                     Foreground="White"
                     Background="#101923"
                     BorderBrush="#27384A"
                     BorderThickness="2"/>

            <Button Grid.Column="1" Content="Поиск" Click="Search_Click" Style="{StaticResource NavButton}"/>
            <Button Grid.Column="2" Content="Маршрут" Click="Route_Click" Style="{StaticResource NavButton}"/>
            <Button Grid.Column="3" Content="В путь" Click="StartNavigation_Click" Style="{StaticResource NavButton}"/>
            <Button Grid.Column="4" Content="Стоп" Click="StopNavigation_Click" Style="{StaticResource NavButton}"/>
            <Button Grid.Column="5" Content="Карта / Спутник" Click="Satellite_Click" Style="{StaticResource NavButton}"/>
        </Grid>

        <Grid Grid.Row="2">
            <Border Background="#101923"
                    BorderBrush="#27384A"
                    BorderThickness="2"
                    CornerRadius="28"
                    Padding="6">
                <wv2:WebView2 x:Name="MapWebView"/>
            </Border>

            <Border x:Name="NavigationInfoPanel"
                    Background="#DD080D14"
                    BorderBrush="#27384A"
                    BorderThickness="2"
                    CornerRadius="24"
                    Padding="22"
                    Margin="20"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Width="480"
                    Visibility="Collapsed">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock x:Name="TurnIconText"
                               Text="↑"
                               FontSize="58"
                               FontWeight="Bold"
                               Foreground="#35D07F"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Column="1">
                        <TextBlock x:Name="NextTurnText"
                                   Text="Маршрут готов"
                                   FontSize="28"
                                   FontWeight="Bold"
                                   TextWrapping="Wrap"
                                   Foreground="White"/>

                        <TextBlock x:Name="RouteInfoText"
                                   Text="-- km • -- min"
                                   FontSize="22"
                                   Foreground="#00C8FF"
                                   Margin="0,10,0,0"/>

                        <TextBlock x:Name="DestinationText"
                                   Text="Цель"
                                   FontSize="18"
                                   Foreground="#718196"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="3" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="LatText" Text="lat: --" FontSize="22" Foreground="White" VerticalAlignment="Center"/>
            <TextBlock x:Name="LonText" Grid.Column="1" Text="lon: --" FontSize="22" Foreground="White" VerticalAlignment="Center"/>
            <TextBlock x:Name="GpsSpeedText" Grid.Column="2" Text="speed: 0 km/h" FontSize="22" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</UserControl>