<UserControl x:Class="CarShell.Pages.BoardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#05080D">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="120"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Поток данных"
                   FontSize="34"
                   FontWeight="Bold"
                   Foreground="White"
                   VerticalAlignment="Center"/>

        <UniformGrid Grid.Row="1" Columns="6" Rows="2">
            <Button Content="ECU" Click="Ecu_Click" Margin="6" FontSize="24"/>
            <Button Content="ABS" Click="Abs_Click" Margin="6" FontSize="24"/>
            <Button Content="UEC" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="REC" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="CIM" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="IPC" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="DDM" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="PDM" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="HVAC" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="RADIO" Click="Body_Click" Margin="6" FontSize="24"/>
            <Button Content="⭐" Click="Fav_Click" Margin="6" FontSize="24"/>
            <Button Content="ВСЕ" Click="All_Click" Margin="6" FontSize="24"/>
        </UniformGrid>

        <Grid Grid.Row="2" Margin="0,18,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="58"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBox x:Name="SearchBox"
                     Height="50"
                     FontSize="22"
                     Padding="14,6"
                     Background="#10151B"
                     Foreground="White"
                     BorderBrush="#27384A"
                     TextChanged="SearchBox_TextChanged"
                     Text=""/>

            <ListView x:Name="DataList"
                      Grid.Row="1"
                      Background="#10151B"
                      BorderBrush="#1C2A38"
                      Foreground="White"
                      FontSize="22">

                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="★" Width="60" DisplayMemberBinding="{Binding FavoriteMark}"/>
                        <GridViewColumn Header="Параметр" Width="360" DisplayMemberBinding="{Binding Name}"/>
                        <GridViewColumn Header="Значение" Width="180" DisplayMemberBinding="{Binding Value}"/>
                        <GridViewColumn Header="Ед." Width="120" DisplayMemberBinding="{Binding Unit}"/>
                        <GridViewColumn Header="Статус" Width="160" DisplayMemberBinding="{Binding Status}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Grid>
    </Grid>
</UserControl>