<UserControl x:Class="CarShell.Pages.UpdatePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#05080D">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="80"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Обновление системы"
                   FontSize="36"
                   FontWeight="Bold"
                   Foreground="White"/>

        <Border Grid.Row="1"
                Background="#10151B"
                BorderBrush="#1C2A38"
                BorderThickness="2"
                CornerRadius="22"
                Padding="30">

            <StackPanel>
                <TextBlock Text="📦 CarShell"
                           FontSize="30"
                           Foreground="White"
                           Margin="0,0,0,20"/>

                <TextBlock x:Name="CurrentVersionText"
                           FontSize="24"
                           Foreground="#8EA0B8"/>

                <TextBlock x:Name="LatestVersionText"
                           FontSize="24"
                           Foreground="#8EA0B8"
                           Margin="0,10,0,0"/>

                <TextBlock x:Name="StatusText"
                           FontSize="26"
                           Foreground="#FFB000"
                           Margin="0,25,0,0"/>

                <TextBlock Text="Описание"
                           FontSize="24"
                           Foreground="White"
                           Margin="0,30,0,10"/>

                <TextBlock x:Name="NotesText"
                           FontSize="20"
                           Foreground="#C8D2E0"
                           TextWrapping="Wrap"
                           MinHeight="120"/>

                <StackPanel Orientation="Horizontal" Margin="0,30,0,0">
                    <Button x:Name="CheckButton"
        Content="Проверить"
        Width="190"
        Height="60"
        FontSize="24"
        Click="CheckUpdate_Click"/>

                    <Button x:Name="DownloadButton"
        Content="Скачать и установить"
        Width="260"
        Height="60"
        FontSize="24"
        Margin="20,0,0,0"
        Click="DownloadUpdate_Click"
        IsEnabled="False"/>

                   
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>