<UserControl x:Class="CarShell.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#05080D">

    <UserControl.Resources>

        <!-- Левая кнопка раздела -->
        <Style x:Key="NavigationButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="72"/>

            <Setter Property="Margin"
                    Value="0,0,0,10"/>

            <Setter Property="Padding"
                    Value="18,0"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>

            <Setter Property="Foreground"
                    Value="#B8C4D4"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="FontSize"
                    Value="21"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#152231"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#1C344B"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- Карточка настройки -->
        <Style x:Key="SettingsCardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="#101820"/>

            <Setter Property="BorderBrush"
                    Value="#1B2A38"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="CornerRadius"
                    Value="18"/>

            <Setter Property="Padding"
                    Value="24"/>

            <Setter Property="Margin"
                    Value="0,0,0,16"/>

        </Style>

        <!-- Обычная кнопка -->
        <Style x:Key="ActionButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="52"/>

            <Setter Property="MinWidth"
                    Value="150"/>

            <Setter Property="Padding"
                    Value="22,0"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#1B6CA8"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="FontSize"
                    Value="18"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.86"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.65"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- Переключатель -->
        <Style x:Key="ToggleSwitchStyle"
               TargetType="CheckBox">

            <Setter Property="Width"
                    Value="70"/>

            <Setter Property="Height"
                    Value="36"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="CheckBox">

                        <Grid Width="70"
                              Height="36">

                            <Border x:Name="SwitchBackground"
                                    Background="#33404D"
                                    CornerRadius="18"/>

                            <Ellipse x:Name="SwitchCircle"
                                     Width="28"
                                     Height="28"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     Margin="4,0,0,0"/>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsChecked"
                                     Value="True">

                                <Setter TargetName="SwitchBackground"
                                        Property="Background"
                                        Value="#1687C9"/>

                                <Setter TargetName="SwitchCircle"
                                        Property="HorizontalAlignment"
                                        Value="Right"/>

                                <Setter TargetName="SwitchCircle"
                                        Property="Margin"
                                        Value="0,0,4,0"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="SwitchBackground"
                                        Property="Opacity"
                                        Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

    </UserControl.Resources>

    <Grid Margin="26">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Width="52"
                    Height="52"
                    Margin="0,0,18,0"
                    Background="#121C25"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="28"
                    Content="‹"
                    Click="BackButton_Click"
                    Cursor="Hand"/>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">

                <TextBlock Text="Настройки"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Управление системой CarShell"
                           Margin="0,3,0,0"
                           FontSize="16"
                           Foreground="#708398"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1"
              Margin="0,16,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="275"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0"
                    Background="#0C1219"
                    BorderBrush="#172431"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="14">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>

                        <Button x:Name="NetworkNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="NetworkNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🌐"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Сеть"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="SystemNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="SystemNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🖥"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Система"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="UpdateNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="UpdateNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="↻"
                                           FontSize="30"
                                           Width="45"/>

                                <TextBlock Text="Обновления"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="CarNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="CarNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🚗"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Автомобиль"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="AboutNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="AboutNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="ⓘ"
                                           FontSize="27"
                                           Width="45"/>

                                <TextBlock Text="О программе"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>
                        <Button x:Name="Explorer"
        Style="{StaticResource NavigationButtonStyle}"
        Click="OpenExplorer_Click">

                            <StackPanel Orientation="Horizontal">


                                <TextBlock Text="Открыть проводник"
                   VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>
                       
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#111B24"
                            CornerRadius="15"
                            Padding="16"
                            Margin="0,12,0,0">

                        <StackPanel>

                            <TextBlock Text="CarShell"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="SidebarVersionText"
                                       Text="Версия 1.0.0"
                                       Foreground="#6F8296"
                                       FontSize="14"
                                       Margin="0,4,0,0"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Border>

            <!-- Правая область -->
            <Grid Grid.Column="2">

                <!-- СЕТЬ -->
                <ScrollViewer x:Name="NetworkPanel"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="Сеть"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Управление беспроводными подключениями"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <!-- Wi-Fi -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Wi-Fi"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="WifiStatusText"
                                               Text="Получение состояния адаптера..."
                                               FontSize="16"
                                               Foreground="#8295A8"
                                               Margin="0,8,0,0"/>

                                    <TextBlock x:Name="ConnectedWifiText"
                                               Text=""
                                               FontSize="15"
                                               Foreground="#39B980"
                                               Margin="0,5,0,0"/>

                                </StackPanel>

                                <CheckBox x:Name="WifiToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Top"
                                          Click="WifiToggle_Click"/>

                            </Grid>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Доступные Wi-Fi сети"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Поиск, подключение и отключение от сетей"
                                               FontSize="15"
                                               Foreground="#8295A8"
                                               Margin="0,7,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="Открыть"
                                        Click="OpenWifiButton_Click"/>

                            </Grid>

                        </Border>

                        <!-- Bluetooth -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Bluetooth"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="BluetoothStatusText"
                                               Text="Получение состояния адаптера..."
                                               FontSize="16"
                                               Foreground="#8295A8"
                                               Margin="0,8,0,0"/>

                                </StackPanel>

                                <CheckBox x:Name="BluetoothToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Top"
                                          Click="BluetoothToggle_Click"/>

                            </Grid>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Bluetooth-устройства"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Сопряжение телефонов, адаптеров и аудиоустройств"
                                               FontSize="15"
                                               Foreground="#8295A8"
                                               Margin="0,7,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="Открыть"
                                        Click="OpenBluetoothButton_Click"/>

                            </Grid>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- СИСТЕМА -->
                <ScrollViewer x:Name="SystemPanel"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="Система"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Основные параметры устройства"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Яркость экрана"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Изменение подсветки дисплея Surface"
                                               Foreground="#8295A8"
                                               FontSize="15"
                                               Margin="0,6,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Настроить"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="BrightnessButton_Click"/>

                            </Grid>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Громкость"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Управление общей громкостью Windows"
                                               Foreground="#8295A8"
                                               FontSize="15"
                                               Margin="0,6,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Настроить"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="VolumeButton_Click"/>

                            </Grid>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Дата и время"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="DateTimeStatusText"
                                               Foreground="#8295A8"
                                               FontSize="15"
                                               Margin="0,6,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Открыть"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Click="DateTimeButton_Click"/>

                            </Grid>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- ОБНОВЛЕНИЯ -->
                <Grid x:Name="UpdatePanel"
                      Visibility="Collapsed">

                    <Frame x:Name="UpdateSettingsFrame"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0"/>

                </Grid>

                <!-- АВТОМОБИЛЬ -->
                <ScrollViewer x:Name="CarPanel"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="Автомобиль"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Подключение CarShell к системам автомобиля"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="CAN-интерфейс"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <TextBlock Text="Настройка подключения STM32 и обмена данными по CAN"
                                           Foreground="#8295A8"
                                           FontSize="15"
                                           Margin="0,6,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="OBD"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <TextBlock Text="Диагностический адаптер и параметры двигателя"
                                           Foreground="#8295A8"
                                           FontSize="15"
                                           Margin="0,6,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="Сон и пробуждение"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <TextBlock Text="Реакция Surface на включение и отключение ACC"
                                           Foreground="#8295A8"
                                           FontSize="15"
                                           Margin="0,6,0,0"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- О ПРОГРАММЕ -->
                <ScrollViewer x:Name="AboutPanel"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="О программе"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Информация о CarShell"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="CarShell"
                                           FontSize="31"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="Автомобильная мультимедийная система"
                                           FontSize="17"
                                           Foreground="#8295A8"
                                           Margin="0,8,0,0"/>

                                <TextBlock x:Name="AboutVersionText"
                                           Text="Версия 1.0.0"
                                           FontSize="16"
                                           Foreground="#4CA9DD"
                                           Margin="0,22,0,0"/>

                                <TextBlock Text="Платформа: Windows 10 IoT Enterprise LTSC 2021"
                                           FontSize="15"
                                           Foreground="#8295A8"
                                           Margin="0,7,0,0"/>

                                <TextBlock Text="Интерфейс: .NET 8 WPF"
                                           FontSize="15"
                                           Foreground="#8295A8"
                                           Margin="0,7,0,0"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Grid>

        </Grid>

    </Grid>

</UserControl>