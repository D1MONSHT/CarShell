<UserControl x:Class="CarShell.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#05080D">

    <UserControl.Resources>
        <Style TargetType="ScrollViewer">

            <Setter Property="VerticalScrollBarVisibility"
            Value="Auto"/>

            <Setter Property="HorizontalScrollBarVisibility"
            Value="Disabled"/>

            <Setter Property="PanningMode"
            Value="VerticalOnly"/>

            <Setter Property="PanningDeceleration"
            Value="0.002"/>

            <Setter Property="PanningRatio"
            Value="1.2"/>

            <Setter Property="IsManipulationEnabled"
            Value="True"/>

            <Setter Property="CanContentScroll"
            Value="False"/>

        </Style>

        <!-- Левая кнопка раздела -->
        <Style x:Key="NavigationButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="72"/>

            <Setter Property="Margin"
                    Value="0,0,0,10"/>

            <Setter Property="Padding"
                    Value="18,0"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>

            <Setter Property="Foreground"
                    Value="#B8C4D4"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="FontSize"
                    Value="21"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#152231"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#1C344B"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- Карточка настройки -->
        <Style x:Key="SettingsCardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="#101820"/>

            <Setter Property="BorderBrush"
                    Value="#1B2A38"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="CornerRadius"
                    Value="18"/>

            <Setter Property="Padding"
                    Value="24"/>

            <Setter Property="Margin"
                    Value="0,0,0,16"/>

        </Style>

        <!-- Обычная кнопка -->
        <Style x:Key="ActionButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="52"/>

            <Setter Property="MinWidth"
                    Value="150"/>

            <Setter Property="Padding"
                    Value="22,0"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#1B6CA8"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="FontSize"
                    Value="18"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.86"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.65"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>

        <!-- Переключатель -->
        <Style x:Key="ToggleSwitchStyle"
               TargetType="CheckBox">

            <Setter Property="Width"
                    Value="70"/>

            <Setter Property="Height"
                    Value="36"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="CheckBox">

                        <Grid Width="70"
                              Height="36">

                            <Border x:Name="SwitchBackground"
                                    Background="#33404D"
                                    CornerRadius="18"/>

                            <Ellipse x:Name="SwitchCircle"
                                     Width="28"
                                     Height="28"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     Margin="4,0,0,0"/>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsChecked"
                                     Value="True">

                                <Setter TargetName="SwitchBackground"
                                        Property="Background"
                                        Value="#1687C9"/>

                                <Setter TargetName="SwitchCircle"
                                        Property="HorizontalAlignment"
                                        Value="Right"/>

                                <Setter TargetName="SwitchCircle"
                                        Property="Margin"
                                        Value="0,0,4,0"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="SwitchBackground"
                                        Property="Opacity"
                                        Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>
        <!-- Подпись поля -->
        <Style x:Key="FieldLabelStyle"
       TargetType="TextBlock">

            <Setter Property="Foreground"
            Value="#8092A8"/>

            <Setter Property="FontSize"
            Value="14"/>

            <Setter Property="Margin"
            Value="0,0,0,8"/>

        </Style>

        <!-- Тёмный ComboBox -->
        <Style x:Key="DarkComboBoxStyle"
       TargetType="ComboBox">

            <Setter Property="Height"
            Value="54"/>

            <Setter Property="Foreground"
            Value="White"/>

            <Setter Property="Background"
            Value="#111C29"/>

            <Setter Property="BorderBrush"
            Value="#26394D"/>

            <Setter Property="BorderThickness"
            Value="1"/>

            <Setter Property="FontSize"
            Value="18"/>

            <Setter Property="Padding"
            Value="14,0"/>

            <Setter Property="VerticalContentAlignment"
            Value="Center"/>

        </Style>

        <!-- Тёмное поле даты -->
        <Style x:Key="DarkDateFieldStyle"
       TargetType="TextBox">

            <Setter Property="Height"
            Value="54"/>

            <Setter Property="Foreground"
            Value="White"/>

            <Setter Property="Background"
            Value="#111C29"/>

            <Setter Property="BorderBrush"
            Value="#26394D"/>

            <Setter Property="BorderThickness"
            Value="1"/>

            <Setter Property="FontSize"
            Value="18"/>

            <Setter Property="Padding"
            Value="16,0"/>

            <Setter Property="VerticalContentAlignment"
            Value="Center"/>

        </Style>

    </UserControl.Resources>

    <Grid Margin="26">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Width="52"
                    Height="52"
                    Margin="0,0,18,0"
                    Background="#121C25"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="28"
                    Content="‹"
                    Click="BackButton_Click"
                    Cursor="Hand"/>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">

                <TextBlock Text="Настройки"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Управление системой CarShell"
                           Margin="0,3,0,0"
                           FontSize="16"
                           Foreground="#708398"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1"
              Margin="0,16,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="275"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель -->
            <Border Grid.Column="0"
                    Background="#0C1219"
                    BorderBrush="#172431"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="14">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>

                        <Button x:Name="NetworkNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="NetworkNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🌐"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Сеть"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="SystemNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="SystemNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🖥"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Система"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="UpdateNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="UpdateNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="↻"
                                           FontSize="30"
                                           Width="45"/>

                                <TextBlock Text="Обновления"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="CarNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="CarNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🚗"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Автомобиль"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="AboutNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="AboutNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="ⓘ"
                                           FontSize="27"
                                           Width="45"/>

                                <TextBlock Text="О программе"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>
                        <Button x:Name="Explorer"
        Style="{StaticResource NavigationButtonStyle}"
        Click="OpenExplorer_Click">

                            <StackPanel Orientation="Horizontal">


                                <TextBlock Text="Открыть проводник"
                   VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>
                       
                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#111B24"
                            CornerRadius="15"
                            Padding="16"
                            Margin="0,12,0,0">

                        <StackPanel>

                            <TextBlock Text="CarShell"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="SidebarVersionText"
                                       Text="Версия 1.0.0"
                                       Foreground="#6F8296"
                                       FontSize="14"
                                       Margin="0,4,0,0"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Border>

            <!-- Правая область -->
            <Grid Grid.Column="2">

                <!-- СЕТЬ -->
                <ScrollViewer x:Name="NetworkPanel"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="Сеть"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Управление беспроводными подключениями"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <!-- Wi-Fi -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Wi-Fi"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="WifiStatusText"
                                               Text="Получение состояния адаптера..."
                                               FontSize="16"
                                               Foreground="#8295A8"
                                               Margin="0,8,0,0"/>

                                    <TextBlock x:Name="ConnectedWifiText"
                                               Text=""
                                               FontSize="15"
                                               Foreground="#39B980"
                                               Margin="0,5,0,0"/>

                                </StackPanel>

                                <CheckBox x:Name="WifiToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Top"
                                          Click="WifiToggle_Click"/>

                            </Grid>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Доступные Wi-Fi сети"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Поиск, подключение и отключение от сетей"
                                               FontSize="15"
                                               Foreground="#8295A8"
                                               Margin="0,7,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="Открыть"
                                        Click="OpenWifiButton_Click"/>

                            </Grid>

                        </Border>

                        <!-- Bluetooth -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Bluetooth"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="BluetoothStatusText"
                                               Text="Получение состояния адаптера..."
                                               FontSize="16"
                                               Foreground="#8295A8"
                                               Margin="0,8,0,0"/>

                                </StackPanel>

                                <CheckBox x:Name="BluetoothToggle"
                                          Grid.Column="1"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Top"
                                          Click="BluetoothToggle_Click"/>

                            </Grid>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>

                                    <TextBlock Text="Bluetooth-устройства"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Сопряжение телефонов, адаптеров и аудиоустройств"
                                               FontSize="15"
                                               Foreground="#8295A8"
                                               Margin="0,7,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="1"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="Открыть"
                                        Click="OpenBluetoothButton_Click"/>

                            </Grid>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- СИСТЕМА -->
                <ScrollViewer x:Name="SystemPanel"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="Система"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Основные параметры устройства"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <!-- ЯРКОСТЬ -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="Яркость экрана"
                           FontSize="21"
                           FontWeight="SemiBold"
                           Foreground="White"/>

                                        <TextBlock Text="Управление подсветкой дисплея Surface"
                           Foreground="#8295A8"
                           FontSize="15"
                           Margin="0,6,0,0"/>

                                    </StackPanel>

                                    <TextBlock x:Name="BrightnessValueText"
                       Grid.Column="1"
                       Text="—%"
                       Foreground="#4CA9DD"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

                                </Grid>

                                <Slider x:Name="BrightnessSlider"
                Minimum="0"
                Maximum="100"
                SmallChange="1"
                LargeChange="10"
                ValueChanged="BrightnessSlider_ValueChanged"
                Margin="0,22,0,0"
                Height="42"/>

                                <TextBlock x:Name="BrightnessErrorText"
                   Visibility="Collapsed"
                   Text="Управление яркостью недоступно"
                   Foreground="#E57373"
                   FontSize="14"
                   Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <!-- ГРОМКОСТЬ -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="Громкость"
                           FontSize="21"
                           FontWeight="SemiBold"
                           Foreground="White"/>

                                        <TextBlock Text="Общая громкость аудиосистемы Windows"
                           Foreground="#8295A8"
                           FontSize="15"
                           Margin="0,6,0,0"/>

                                    </StackPanel>

                                    <TextBlock x:Name="VolumeValueText"
                       Grid.Column="1"
                       Text="—%"
                       Foreground="#4CA9DD"
                       FontSize="22"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"/>

                                </Grid>

                                <Slider x:Name="VolumeSlider"
                Minimum="0"
                Maximum="100"
                SmallChange="1"
                LargeChange="10"
                ValueChanged="VolumeSlider_ValueChanged"
                Margin="0,22,0,0"
                Height="42"/>

                                <Grid Margin="0,14,0,0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">

                                        <TextBlock Text="Отключить звук"
                           Foreground="White"
                           FontSize="17"/>

                                        <TextBlock x:Name="MuteStatusText"
                           Text="Звук включён"
                           Foreground="#8295A8"
                           FontSize="14"
                           Margin="0,4,0,0"/>

                                    </StackPanel>

                                    <CheckBox x:Name="MuteToggle"
                      Grid.Column="1"
                      Style="{StaticResource ToggleSwitchStyle}"
                      VerticalAlignment="Center"
                      Click="MuteToggle_Click"/>

                                </Grid>

                            </StackPanel>

                        </Border>
                        <!-- ДАТА И ВРЕМЯ -->
                        <!-- ДАТА И ВРЕМЯ -->
                        <Border Style="{StaticResource SettingsCardStyle}"
        Padding="28">

                            <StackPanel>

                                <!-- Верхняя часть -->
                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="62"
                    Height="62"
                    Background="#12395B"
                    CornerRadius="16">

                                        <TextBlock Text="◷"
                           Foreground="#2A9DFF"
                           FontSize="38"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>

                                    </Border>

                                    <StackPanel Grid.Column="2"
                        VerticalAlignment="Center">

                                        <TextBlock Text="Дата и время"
                           Foreground="White"
                           FontSize="24"
                           FontWeight="SemiBold"/>

                                        <TextBlock Text="Текущие системные дата и время"
                           Foreground="#8295A8"
                           FontSize="15"
                           Margin="0,6,0,0"/>

                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                        HorizontalAlignment="Right">

                                        <TextBlock x:Name="CurrentTimeText"
                           Text="17:07"
                           Foreground="White"
                           FontSize="34"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Right"/>

                                        <TextBlock x:Name="CurrentDateText"
                           Text="12 июля 2026 г."
                           Foreground="#D7E0EA"
                           FontSize="16"
                           Margin="0,4,0,0"
                           HorizontalAlignment="Right"/>

                                        <TextBlock x:Name="CurrentDayOfWeekText"
                           Text="Воскресенье"
                           Foreground="#8295A8"
                           FontSize="14"
                           Margin="0,3,0,0"
                           HorizontalAlignment="Right"/>

                                    </StackPanel>

                                </Grid>

                                <Border Height="1"
                Background="#263746"
                Margin="0,22,0,20"/>

                                <!-- Редактор даты и времени -->
                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ДАТА -->
                                    <Border Grid.Column="0"
                    Background="#0D1722"
                    BorderBrush="#223548"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20">

                                        <StackPanel>

                                            <TextBlock Text="Дата"
                               Foreground="#8295A8"
                               FontSize="15"/>

                                            <TextBlock x:Name="SelectedDateText"
                               Text="12 июля 2026"
                               Foreground="White"
                               FontSize="24"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,18"/>

                                            <!-- День -->
                                            <Grid Margin="0,0,0,12">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="День"
                                   Foreground="#B9C6D4"
                                   FontSize="17"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                Content="−"
                                FontSize="26"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="50"
                                Click="DayMinusButton_Click"/>

                                                <TextBlock x:Name="DayValueText"
                                   Grid.Column="2"
                                   Text="12"
                                   Foreground="#2A9DFF"
                                   FontSize="25"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                Content="+"
                                FontSize="25"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="50"
                                Click="DayPlusButton_Click"/>

                                            </Grid>

                                            <!-- Месяц -->
                                            <Grid Margin="0,0,0,12">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Месяц"
                                   Foreground="#B9C6D4"
                                   FontSize="17"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                Content="−"
                                FontSize="26"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="50"
                                Click="MonthMinusButton_Click"/>

                                                <TextBlock x:Name="MonthValueText"
                                   Grid.Column="2"
                                   Text="Июль"
                                   Foreground="#2A9DFF"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                Content="+"
                                FontSize="25"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="50"
                                Click="MonthPlusButton_Click"/>

                                            </Grid>

                                            <!-- Год -->
                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Год"
                                   Foreground="#B9C6D4"
                                   FontSize="17"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                Content="−"
                                FontSize="26"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="50"
                                Click="YearMinusButton_Click"/>

                                                <TextBlock x:Name="YearValueText"
                                   Grid.Column="2"
                                   Text="2026"
                                   Foreground="#2A9DFF"
                                   FontSize="25"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                Content="+"
                                FontSize="25"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="50"
                                Click="YearPlusButton_Click"/>

                                            </Grid>

                                        </StackPanel>

                                    </Border>

                                    <!-- ВРЕМЯ -->
                                    <Border Grid.Column="2"
                    Background="#0D1722"
                    BorderBrush="#223548"
                    BorderThickness="1"
                    CornerRadius="16"
                    Padding="20">

                                        <StackPanel>

                                            <TextBlock Text="Время"
                               Foreground="#8295A8"
                               FontSize="15"/>

                                            <TextBlock x:Name="SelectedTimeText"
                               Text="17:07"
                               Foreground="White"
                               FontSize="36"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,24"/>

                                            <!-- Часы -->
                                            <Grid Margin="0,0,0,18">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Часы"
                                   Foreground="#B9C6D4"
                                   FontSize="17"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                Content="−"
                                FontSize="26"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="56"
                                Click="HourMinusButton_Click"/>

                                                <TextBlock x:Name="HourValueText"
                                   Grid.Column="2"
                                   Text="17"
                                   Foreground="#2A9DFF"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                Content="+"
                                FontSize="25"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="56"
                                Click="HourPlusButton_Click"/>

                                            </Grid>

                                            <!-- Минуты -->
                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Минуты"
                                   Foreground="#B9C6D4"
                                   FontSize="17"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                Content="−"
                                FontSize="26"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="56"
                                Click="MinuteMinusButton_Click"/>

                                                <TextBlock x:Name="MinuteValueText"
                                   Grid.Column="2"
                                   Text="07"
                                   Foreground="#2A9DFF"
                                   FontSize="30"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                Content="+"
                                FontSize="25"
                                Background="#1A2A3B"
                                Foreground="White"
                                BorderThickness="0"
                                Height="56"
                                Click="MinutePlusButton_Click"/>

                                            </Grid>

                                        </StackPanel>

                                    </Border>

                                </Grid>

                                <!-- Кнопки -->
                                <Grid Margin="0,22,0,0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="240"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="1"
                    Content="✓  Применить"
                    Style="{StaticResource ActionButtonStyle}"
                    Click="ApplyDateTimeButton_Click"/>

                                    <Button Grid.Column="3"
                    Content="⟳  Синхронизировать"
                    Style="{StaticResource ActionButtonStyle}"
                    Background="#223548"
                    Click="SynchronizeTimeButton_Click"/>

                                </Grid>

                                <TextBlock x:Name="DateTimeResultText"
                   Text="Изменения применяются к системному времени Windows"
                   Foreground="#71849A"
                   FontSize="14"
                   Margin="0,16,0,0"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- ОБНОВЛЕНИЯ -->
                <Grid x:Name="UpdatePanel"
                      Visibility="Collapsed">

                    <Frame x:Name="UpdateSettingsFrame"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0"/>

                </Grid>

                <!-- АВТОМОБИЛЬ -->
                <ScrollViewer x:Name="CarPanel"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="Автомобиль"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Подключение CarShell к системам автомобиля"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="CAN-интерфейс"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <TextBlock Text="Настройка подключения STM32 и обмена данными по CAN"
                                           Foreground="#8295A8"
                                           FontSize="15"
                                           Margin="0,6,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="OBD"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <TextBlock Text="Диагностический адаптер и параметры двигателя"
                                           Foreground="#8295A8"
                                           FontSize="15"
                                           Margin="0,6,0,0"/>

                            </StackPanel>

                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="Сон и пробуждение"
                                           FontSize="21"
                                           FontWeight="SemiBold"
                                           Foreground="White"/>

                                <TextBlock Text="Реакция Surface на включение и отключение ACC"
                                           Foreground="#8295A8"
                                           FontSize="15"
                                           Margin="0,6,0,0"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- О ПРОГРАММЕ -->
                <ScrollViewer x:Name="AboutPanel"
                              Visibility="Collapsed"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">

                    <StackPanel>

                        <TextBlock Text="О программе"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Информация о CarShell"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <TextBlock Text="CarShell"
                                           FontSize="31"
                                           FontWeight="Bold"
                                           Foreground="White"/>

                                <TextBlock Text="Автомобильная мультимедийная система"
                                           FontSize="17"
                                           Foreground="#8295A8"
                                           Margin="0,8,0,0"/>

                                <TextBlock x:Name="AboutVersionText"
                                           Text="Версия 1.0.0"
                                           FontSize="16"
                                           Foreground="#4CA9DD"
                                           Margin="0,22,0,0"/>

                                <TextBlock Text="Платформа: Windows 10 IoT Enterprise LTSC 2021"
                                           FontSize="15"
                                           Foreground="#8295A8"
                                           Margin="0,7,0,0"/>

                                <TextBlock Text="Интерфейс: .NET 8 WPF"
                                           FontSize="15"
                                           Foreground="#8295A8"
                                           Margin="0,7,0,0"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

            </Grid>

        </Grid>

    </Grid>

</UserControl>