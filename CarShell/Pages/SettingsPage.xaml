<UserControl x:Class="CarShell.Pages.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settings="clr-namespace:CarShell.Pages.Settings"
             Background="#05080D">

    <UserControl.Resources>

        <!-- ЛЕВАЯ КНОПКА РАЗДЕЛА -->
        <Style x:Key="NavigationButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="72"/>

            <Setter Property="Margin"
                    Value="0,0,0,10"/>

            <Setter Property="Padding"
                    Value="18,0"/>

            <Setter Property="HorizontalContentAlignment"
                    Value="Left"/>

            <Setter Property="VerticalContentAlignment"
                    Value="Center"/>

            <Setter Property="Foreground"
                    Value="#B8C4D4"/>

            <Setter Property="Background"
                    Value="Transparent"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="FontSize"
                    Value="21"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">

                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#152231"/>

                                <Setter Property="Foreground"
                                        Value="White"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Background"
                                        Value="#1C344B"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- КАРТОЧКА НАСТРОЙКИ -->
        <Style x:Key="SettingsCardStyle"
               TargetType="Border">

            <Setter Property="Background"
                    Value="#101820"/>

            <Setter Property="BorderBrush"
                    Value="#1B2A38"/>

            <Setter Property="BorderThickness"
                    Value="1"/>

            <Setter Property="CornerRadius"
                    Value="18"/>

            <Setter Property="Padding"
                    Value="24"/>

            <Setter Property="Margin"
                    Value="0,0,0,16"/>

        </Style>

        <!-- ОБЫЧНАЯ КНОПКА -->
        <Style x:Key="ActionButtonStyle"
               TargetType="Button">

            <Setter Property="Height"
                    Value="52"/>

            <Setter Property="MinWidth"
                    Value="150"/>

            <Setter Property="Padding"
                    Value="22,0"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#1B6CA8"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="FontSize"
                    Value="18"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.86"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.65"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="ButtonBorder"
                                        Property="Opacity"
                                        Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- КНОПКА ПЛЮС / МИНУС -->
        <Style x:Key="ValueButtonStyle"
               TargetType="Button">

            <Setter Property="Width"
                    Value="66"/>

            <Setter Property="Height"
                    Value="56"/>

            <Setter Property="Foreground"
                    Value="White"/>

            <Setter Property="Background"
                    Value="#1A2A3B"/>

            <Setter Property="BorderThickness"
                    Value="0"/>

            <Setter Property="FontSize"
                    Value="27"/>

            <Setter Property="FontWeight"
                    Value="SemiBold"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="Button">

                        <Border x:Name="ValueButtonBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="13">

                            <ContentPresenter
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"/>

                        </Border>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsMouseOver"
                                     Value="True">

                                <Setter TargetName="ValueButtonBorder"
                                        Property="Background"
                                        Value="#243D55"/>

                            </Trigger>

                            <Trigger Property="IsPressed"
                                     Value="True">

                                <Setter TargetName="ValueButtonBorder"
                                        Property="Background"
                                        Value="#126FA9"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- ПЕРЕКЛЮЧАТЕЛЬ -->
        <Style x:Key="ToggleSwitchStyle"
               TargetType="CheckBox">

            <Setter Property="Width"
                    Value="70"/>

            <Setter Property="Height"
                    Value="36"/>

            <Setter Property="Cursor"
                    Value="Hand"/>

            <Setter Property="Template">

                <Setter.Value>

                    <ControlTemplate TargetType="CheckBox">

                        <Grid Width="70"
                              Height="36">

                            <Border x:Name="SwitchBackground"
                                    Background="#33404D"
                                    CornerRadius="18"/>

                            <Ellipse x:Name="SwitchCircle"
                                     Width="28"
                                     Height="28"
                                     Fill="White"
                                     HorizontalAlignment="Left"
                                     Margin="4,0,0,0"/>

                        </Grid>

                        <ControlTemplate.Triggers>

                            <Trigger Property="IsChecked"
                                     Value="True">

                                <Setter TargetName="SwitchBackground"
                                        Property="Background"
                                        Value="#1687C9"/>

                                <Setter TargetName="SwitchCircle"
                                        Property="HorizontalAlignment"
                                        Value="Right"/>

                                <Setter TargetName="SwitchCircle"
                                        Property="Margin"
                                        Value="0,0,4,0"/>

                            </Trigger>

                            <Trigger Property="IsEnabled"
                                     Value="False">

                                <Setter TargetName="SwitchBackground"
                                        Property="Opacity"
                                        Value="0.35"/>

                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>

            </Setter>

        </Style>

        <!-- СЕНСОРНАЯ ПРОКРУТКА -->
        <!-- СЕНСОРНАЯ ПРОКРУТКА БЕЗ ВИДИМОЙ ПОЛОСЫ -->
        <Style TargetType="ScrollViewer">

            <Setter Property="VerticalScrollBarVisibility"
            Value="Hidden"/>

            <Setter Property="HorizontalScrollBarVisibility"
            Value="Disabled"/>

            <Setter Property="PanningMode"
            Value="VerticalOnly"/>

            <Setter Property="PanningDeceleration"
            Value="0.0015"/>

            <Setter Property="PanningRatio"
            Value="1.15"/>

            <Setter Property="CanContentScroll"
            Value="False"/>

            <Setter Property="IsManipulationEnabled"
            Value="True"/>

            <Setter Property="Focusable"
            Value="False"/>

        </Style>
    </UserControl.Resources>

    <Grid Margin="26">

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ВЕРХНИЙ ЗАГОЛОВОК -->
        <Grid Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Width="52"
                    Height="52"
                    Margin="0,0,18,0"
                    Background="#121C25"
                    Foreground="White"
                    BorderThickness="0"
                    FontSize="28"
                    Content="‹"
                    Click="BackButton_Click"
                    Cursor="Hand"/>

            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">

                <TextBlock Text="Настройки"
                           FontSize="34"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Text="Управление системой CarShell"
                           Margin="0,3,0,0"
                           FontSize="16"
                           Foreground="#708398"/>

            </StackPanel>

        </Grid>

        <Grid Grid.Row="1"
              Margin="0,16,0,0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="275"/>
                <ColumnDefinition Width="22"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ЛЕВАЯ ПАНЕЛЬ -->
            <Border Grid.Column="0"
                    Background="#0C1219"
                    BorderBrush="#172431"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="14">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel>

                        <Button x:Name="NetworkNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="NetworkNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🌐"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Сеть"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="SystemNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="SystemNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🖥"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Система"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="UpdateNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="UpdateNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="↻"
                                           FontSize="30"
                                           Width="45"/>

                                <TextBlock Text="Обновления"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="CarNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="CarNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="🚗"
                                           FontSize="25"
                                           Width="45"/>

                                <TextBlock Text="Автомобиль"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="AboutNavigationButton"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="AboutNavigationButton_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="ⓘ"
                                           FontSize="27"
                                           Width="45"/>

                                <TextBlock Text="О программе"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                        <Button x:Name="Explorer"
                                Style="{StaticResource NavigationButtonStyle}"
                                Click="OpenExplorer_Click">

                            <StackPanel Orientation="Horizontal">

                                <TextBlock Text="📁"
                                           FontSize="23"
                                           Width="45"/>

                                <TextBlock Text="Проводник"
                                           VerticalAlignment="Center"/>

                            </StackPanel>

                        </Button>

                    </StackPanel>

                    <Border Grid.Row="1"
                            Background="#111B24"
                            CornerRadius="15"
                            Padding="16"
                            Margin="0,12,0,0">

                        <StackPanel>

                            <TextBlock Text="CarShell"
                                       Foreground="White"
                                       FontSize="18"
                                       FontWeight="SemiBold"/>

                            <TextBlock x:Name="SidebarVersionText"
                                       Text="Версия 1.0.0"
                                       Foreground="#6F8296"
                                       FontSize="14"
                                       Margin="0,4,0,0"/>

                        </StackPanel>

                    </Border>

                </Grid>

            </Border>

            <!-- ПРАВАЯ ОБЛАСТЬ -->
            <Grid Grid.Column="2">

                <!-- ================================================= -->
                <!-- СЕТЬ -->
                <!-- ================================================= -->

                <ScrollViewer x:Name="NetworkPanel">

                    <StackPanel Margin="0,0,0,100">

                        <TextBlock Text="Сеть"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Управление беспроводными подключениями"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <!-- WI-FI -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="58"
                                        Height="58"
                                        Background="#102E49"
                                        CornerRadius="15">

                                    <TextBlock Text="⌁"
                                               Foreground="#2A9DFF"
                                               FontSize="38"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                </Border>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="Wi-Fi"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="WifiStatusText"
                                               Text="Получение состояния адаптера..."
                                               FontSize="16"
                                               Foreground="#8295A8"
                                               Margin="0,7,0,0"/>

                                    <TextBlock x:Name="ConnectedWifiText"
                                               Text=""
                                               FontSize="15"
                                               Foreground="#39B980"
                                               Margin="0,5,0,0"/>

                                </StackPanel>

                                <CheckBox x:Name="WifiToggle"
                                          Grid.Column="3"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Click="WifiToggle_Click"/>

                            </Grid>

                        </Border>

                        <!-- ДОСТУПНЫЕ СЕТИ -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="58"
                                        Height="58"
                                        Background="#102E49"
                                        CornerRadius="15">

                                    <TextBlock Text="≋"
                                               Foreground="#2A9DFF"
                                               FontSize="34"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                </Border>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="Доступные Wi-Fi сети"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Поиск, подключение и отключение от сетей"
                                               FontSize="15"
                                               Foreground="#8295A8"
                                               Margin="0,7,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="3"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="Открыть"
                                        Click="OpenWifiButton_Click"/>

                            </Grid>

                        </Border>

                        <!-- BLUETOOTH -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="58"
                                        Height="58"
                                        Background="#102E49"
                                        CornerRadius="15">

                                    <TextBlock Text="ᛒ"
                                               Foreground="#2A9DFF"
                                               FontSize="33"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                </Border>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="Bluetooth"
                                               FontSize="24"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock x:Name="BluetoothStatusText"
                                               Text="Получение состояния адаптера..."
                                               FontSize="16"
                                               Foreground="#8295A8"
                                               Margin="0,8,0,0"/>

                                </StackPanel>

                                <CheckBox x:Name="BluetoothToggle"
                                          Grid.Column="3"
                                          Style="{StaticResource ToggleSwitchStyle}"
                                          VerticalAlignment="Center"
                                          Click="BluetoothToggle_Click"/>

                            </Grid>

                        </Border>

                        <!-- BLUETOOTH УСТРОЙСТВА -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <Grid>

                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="18"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <Border Width="58"
                                        Height="58"
                                        Background="#102E49"
                                        CornerRadius="15">

                                    <TextBlock Text="◉"
                                               Foreground="#2A9DFF"
                                               FontSize="30"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"/>

                                </Border>

                                <StackPanel Grid.Column="2"
                                            VerticalAlignment="Center">

                                    <TextBlock Text="Bluetooth-устройства"
                                               FontSize="21"
                                               FontWeight="SemiBold"
                                               Foreground="White"/>

                                    <TextBlock Text="Телефоны, адаптеры и аудиоустройства"
                                               FontSize="15"
                                               Foreground="#8295A8"
                                               Margin="0,7,0,0"/>

                                </StackPanel>

                                <Button Grid.Column="3"
                                        Style="{StaticResource ActionButtonStyle}"
                                        Content="Открыть"
                                        Click="OpenBluetoothButton_Click"/>

                            </Grid>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- ================================================= -->
                <!-- СИСТЕМА -->
                <!-- ================================================= -->

                <ScrollViewer x:Name="SystemPanel"
                              Visibility="Collapsed">

                    <StackPanel Margin="0,0,0,100">

                        <TextBlock Text="Система"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="White"/>

                        <TextBlock Text="Основные параметры устройства"
                                   FontSize="17"
                                   Foreground="#778A9E"
                                   Margin="0,5,0,24"/>

                        <!-- ЯРКОСТЬ -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="Яркость экрана"
                                                   FontSize="21"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>

                                        <TextBlock Text="Управление подсветкой дисплея Surface"
                                                   Foreground="#8295A8"
                                                   FontSize="15"
                                                   Margin="0,6,0,0"/>

                                    </StackPanel>

                                    <TextBlock x:Name="BrightnessValueText"
                                               Grid.Column="1"
                                               Text="—%"
                                               Foreground="#4CA9DD"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                </Grid>

                                <Slider x:Name="BrightnessSlider"
                                        Minimum="0"
                                        Maximum="100"
                                        SmallChange="1"
                                        LargeChange="10"
                                        ValueChanged="BrightnessSlider_ValueChanged"
                                        Margin="0,22,0,0"
                                        Height="42"/>

                                <TextBlock x:Name="BrightnessErrorText"
                                           Visibility="Collapsed"
                                           Text="Управление яркостью недоступно"
                                           Foreground="#E57373"
                                           FontSize="14"
                                           Margin="0,8,0,0"/>

                            </StackPanel>

                        </Border>

                        <!-- ГРОМКОСТЬ -->
                        <Border Style="{StaticResource SettingsCardStyle}">

                            <StackPanel>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel>

                                        <TextBlock Text="Громкость"
                                                   FontSize="21"
                                                   FontWeight="SemiBold"
                                                   Foreground="White"/>

                                        <TextBlock Text="Общая громкость аудиосистемы Windows"
                                                   Foreground="#8295A8"
                                                   FontSize="15"
                                                   Margin="0,6,0,0"/>

                                    </StackPanel>

                                    <TextBlock x:Name="VolumeValueText"
                                               Grid.Column="1"
                                               Text="—%"
                                               Foreground="#4CA9DD"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>

                                </Grid>

                                <Slider x:Name="VolumeSlider"
                                        Minimum="0"
                                        Maximum="100"
                                        SmallChange="1"
                                        LargeChange="10"
                                        ValueChanged="VolumeSlider_ValueChanged"
                                        Margin="0,22,0,0"
                                        Height="42"/>

                                <Grid Margin="0,14,0,0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel VerticalAlignment="Center">

                                        <TextBlock Text="Отключить звук"
                                                   Foreground="White"
                                                   FontSize="17"/>

                                        <TextBlock x:Name="MuteStatusText"
                                                   Text="Звук включён"
                                                   Foreground="#8295A8"
                                                   FontSize="14"
                                                   Margin="0,4,0,0"/>

                                    </StackPanel>

                                    <CheckBox x:Name="MuteToggle"
                                              Grid.Column="1"
                                              Style="{StaticResource ToggleSwitchStyle}"
                                              VerticalAlignment="Center"
                                              Click="MuteToggle_Click"/>

                                </Grid>

                            </StackPanel>

                        </Border>

                        <!-- ДАТА И ВРЕМЯ -->
                        <Border Style="{StaticResource SettingsCardStyle}"
                                Padding="28">

                            <StackPanel>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="62"
                                            Height="62"
                                            Background="#12395B"
                                            CornerRadius="16">

                                        <TextBlock Text="◷"
                                                   Foreground="#2A9DFF"
                                                   FontSize="38"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>

                                    </Border>

                                    <StackPanel Grid.Column="2"
                                                VerticalAlignment="Center">

                                        <TextBlock Text="Дата и время"
                                                   Foreground="White"
                                                   FontSize="24"
                                                   FontWeight="SemiBold"/>

                                        <TextBlock Text="Текущие системные дата и время"
                                                   Foreground="#8295A8"
                                                   FontSize="15"
                                                   Margin="0,6,0,0"/>

                                    </StackPanel>

                                    <StackPanel Grid.Column="3"
                                                HorizontalAlignment="Right">

                                        <TextBlock x:Name="CurrentTimeText"
                                                   Text="17:07"
                                                   Foreground="White"
                                                   FontSize="34"
                                                   FontWeight="SemiBold"
                                                   HorizontalAlignment="Right"/>

                                        <TextBlock x:Name="CurrentDateText"
                                                   Text="12 июля 2026 г."
                                                   Foreground="#D7E0EA"
                                                   FontSize="16"
                                                   Margin="0,4,0,0"
                                                   HorizontalAlignment="Right"/>

                                        <TextBlock x:Name="CurrentDayOfWeekText"
                                                   Text="Воскресенье"
                                                   Foreground="#8295A8"
                                                   FontSize="14"
                                                   Margin="0,3,0,0"
                                                   HorizontalAlignment="Right"/>

                                    </StackPanel>

                                </Grid>

                                <Border Height="1"
                                        Background="#263746"
                                        Margin="0,22,0,20"/>

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="3*"/>
                                        <ColumnDefinition Width="24"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- ДАТА -->
                                    <Border Grid.Column="0"
                                            Background="#0D1722"
                                            BorderBrush="#223548"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="22">

                                        <StackPanel>

                                            <TextBlock Text="Дата"
                                                       Foreground="#8295A8"
                                                       FontSize="15"/>

                                            <TextBlock x:Name="SelectedDateText"
                                                       Text="12 июля 2026"
                                                       Foreground="White"
                                                       FontSize="25"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,12,0,20"/>

                                            <!-- ДЕНЬ -->
                                            <Grid Margin="0,0,0,14">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="66"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="66"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="День"
                                                           Foreground="#B9C6D4"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="−"
                                                        Click="DayMinusButton_Click"/>

                                                <TextBlock x:Name="DayValueText"
                                                           Grid.Column="2"
                                                           Text="12"
                                                           Foreground="#2A9DFF"
                                                           FontSize="29"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="+"
                                                        Click="DayPlusButton_Click"/>

                                            </Grid>

                                            <!-- МЕСЯЦ -->
                                            <Grid Margin="0,0,0,14">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="66"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="66"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Месяц"
                                                           Foreground="#B9C6D4"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="−"
                                                        Click="MonthMinusButton_Click"/>

                                                <TextBlock x:Name="MonthValueText"
                                                           Grid.Column="2"
                                                           Text="Июль"
                                                           Foreground="#2A9DFF"
                                                           FontSize="24"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="+"
                                                        Click="MonthPlusButton_Click"/>

                                            </Grid>

                                            <!-- ГОД -->
                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="110"/>
                                                    <ColumnDefinition Width="66"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="66"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Год"
                                                           Foreground="#B9C6D4"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="−"
                                                        Click="YearMinusButton_Click"/>

                                                <TextBlock x:Name="YearValueText"
                                                           Grid.Column="2"
                                                           Text="2026"
                                                           Foreground="#2A9DFF"
                                                           FontSize="29"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="+"
                                                        Click="YearPlusButton_Click"/>

                                            </Grid>

                                        </StackPanel>

                                    </Border>

                                    <!-- ВРЕМЯ -->
                                    <Border Grid.Column="2"
                                            Background="#0D1722"
                                            BorderBrush="#223548"
                                            BorderThickness="1"
                                            CornerRadius="16"
                                            Padding="22">

                                        <StackPanel>

                                            <TextBlock Text="Время"
                                                       Foreground="#8295A8"
                                                       FontSize="15"/>

                                            <TextBlock x:Name="SelectedTimeText"
                                                       Text="17:07"
                                                       Foreground="White"
                                                       FontSize="38"
                                                       FontWeight="SemiBold"
                                                       HorizontalAlignment="Center"
                                                       Margin="0,12,0,25"/>

                                            <!-- ЧАСЫ -->
                                            <Grid Margin="0,0,0,18">

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="66"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="66"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Часы"
                                                           Foreground="#B9C6D4"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="−"
                                                        Click="HourMinusButton_Click"/>

                                                <TextBlock x:Name="HourValueText"
                                                           Grid.Column="2"
                                                           Text="17"
                                                           Foreground="#2A9DFF"
                                                           FontSize="31"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="+"
                                                        Click="HourPlusButton_Click"/>

                                            </Grid>

                                            <!-- МИНУТЫ -->
                                            <Grid>

                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="66"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="66"/>
                                                </Grid.ColumnDefinitions>

                                                <TextBlock Text="Минуты"
                                                           Foreground="#B9C6D4"
                                                           FontSize="18"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="1"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="−"
                                                        Click="MinuteMinusButton_Click"/>

                                                <TextBlock x:Name="MinuteValueText"
                                                           Grid.Column="2"
                                                           Text="07"
                                                           Foreground="#2A9DFF"
                                                           FontSize="31"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>

                                                <Button Grid.Column="3"
                                                        Style="{StaticResource ValueButtonStyle}"
                                                        Content="+"
                                                        Click="MinutePlusButton_Click"/>

                                            </Grid>

                                        </StackPanel>

                                    </Border>

                                </Grid>

                                <Grid Margin="0,22,0,0">

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="190"/>
                                        <ColumnDefinition Width="14"/>
                                        <ColumnDefinition Width="240"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="1"
                                            Content="✓  Применить"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Click="ApplyDateTimeButton_Click"/>

                                    <Button Grid.Column="3"
                                            Content="⟳  Синхронизировать"
                                            Style="{StaticResource ActionButtonStyle}"
                                            Background="#223548"
                                            Click="SynchronizeTimeButton_Click"/>

                                </Grid>

                                <TextBlock x:Name="DateTimeResultText"
                                           Text="Изменения применяются к системному времени Windows"
                                           Foreground="#71849A"
                                           FontSize="14"
                                           Margin="0,16,0,0"/>

                            </StackPanel>

                        </Border>

                    </StackPanel>

                </ScrollViewer>

                <!-- ================================================= -->
                <!-- ОБНОВЛЕНИЯ -->
                <!-- ================================================= -->

                <Grid x:Name="UpdatePanel"
                      Visibility="Collapsed">

                    <Frame x:Name="UpdateSettingsFrame"
                           NavigationUIVisibility="Hidden"
                           Background="Transparent"
                           BorderThickness="0"/>

                </Grid>

                <!-- ================================================= -->
                <!-- АВТОМОБИЛЬ -->
                <!-- ================================================= -->

                <Grid x:Name="CarPanel"
                      Visibility="Collapsed">

                    <settings:CarSettingsControl/>

                </Grid>

                <!-- ================================================= -->
                <!-- О ПРОГРАММЕ -->
                <!-- ================================================= -->

                <Grid x:Name="AboutPanel"
                      Visibility="Collapsed">

                    <settings:AboutSettingsControl/>

                </Grid>

                <!-- ================================================= -->
                <!-- СПИСОК WI-FI СЕТЕЙ -->
                <!-- ================================================= -->

                <Grid x:Name="WifiNetworksPanel"
                      Visibility="Collapsed"
                      Background="#05080D"
                      Panel.ZIndex="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Width="52"
                                Height="52"
                                Content="‹"
                                Background="#121C25"
                                Foreground="White"
                                BorderThickness="0"
                                FontSize="28"
                                Cursor="Hand"
                                Click="CloseWifiNetworksButton_Click"/>

                        <StackPanel Grid.Column="2"
                                    VerticalAlignment="Center">

                            <TextBlock Text="Доступные сети"
                                       Foreground="White"
                                       FontSize="30"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="WifiNetworksStatusText"
                                       Text="Поиск беспроводных сетей"
                                       Foreground="#778A9E"
                                       FontSize="15"
                                       Margin="0,4,0,0"/>

                        </StackPanel>

                        <Button Grid.Column="3"
                                Content="↻  Обновить"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="RefreshWifiNetworksButton_Click"/>

                    </Grid>

                    <ScrollViewer Grid.Row="2">

                        <StackPanel x:Name="WifiNetworksStackPanel"
                                    Margin="0,0,0,100"/>

                    </ScrollViewer>

                </Grid>
                <!-- СПИСОК BLUETOOTH-УСТРОЙСТВ -->
                <!-- BLUETOOTH-УСТРОЙСТВА -->
                <Grid x:Name="BluetoothDevicesPanel"
      Visibility="Collapsed"
      Background="#05080D"
      Panel.ZIndex="20">

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="18"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Заголовок -->
                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="18"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Button Width="52"
                Height="52"
                Content="‹"
                Background="#121C25"
                Foreground="White"
                BorderThickness="0"
                FontSize="28"
                Cursor="Hand"
                Click="CloseBluetoothDevicesButton_Click"/>

                        <StackPanel Grid.Column="2"
                    VerticalAlignment="Center">

                            <TextBlock Text="Bluetooth-устройства"
                       Foreground="White"
                       FontSize="30"
                       FontWeight="Bold"/>

                            <TextBlock x:Name="BluetoothDevicesStatusText"
                       Text="Поиск устройств"
                       Foreground="#778A9E"
                       FontSize="15"
                       Margin="0,4,0,0"/>

                        </StackPanel>

                        <Button Grid.Column="3"
                Content="↻  Обновить"
                Style="{StaticResource ActionButtonStyle}"
                Click="RefreshBluetoothDevicesButton_Click"/>

                    </Grid>

                    <ScrollViewer Grid.Row="2">

                        <StackPanel Margin="0,0,0,100">

                            <!-- Информация о CarShell -->
                            <Border Style="{StaticResource SettingsCardStyle}">

                                <Grid>

                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Width="56"
                            Height="56"
                            Background="#102E49"
                            CornerRadius="15">

                                        <TextBlock Text="ᛒ"
                                   Foreground="#2A9DFF"
                                   FontSize="32"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>

                                    </Border>

                                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center">

                                        <TextBlock Text="Это устройство"
                                   Foreground="#8295A8"
                                   FontSize="14"/>

                                        <TextBlock x:Name="BluetoothComputerNameText"
                                   Text="CarShell"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   Margin="0,4,0,0"/>

                                    </StackPanel>

                                    <TextBlock Grid.Column="2"
                               Text="Видимо для устройств"
                               Foreground="#39B980"
                               FontSize="15"
                               VerticalAlignment="Center"/>

                                </Grid>

                            </Border>

                            <!-- Подключённые и сопряжённые -->
                            <TextBlock Text="Подключённые и сохранённые"
                       Foreground="White"
                       FontSize="21"
                       FontWeight="SemiBold"
                       Margin="0,12,0,14"/>

                            <StackPanel x:Name="BluetoothPairedDevicesStackPanel"/>

                            <!-- Доступные -->
                            <TextBlock Text="Доступные устройства"
                       Foreground="White"
                       FontSize="21"
                       FontWeight="SemiBold"
                       Margin="0,18,0,14"/>

                            <StackPanel x:Name="BluetoothAvailableDevicesStackPanel"/>

                        </StackPanel>

                    </ScrollViewer>

                </Grid>

            </Grid>

        </Grid>

        <!-- ========================================================= -->
        <!-- ОКНО ВВОДА ПАРОЛЯ WI-FI -->
        <!-- ========================================================= -->

        <Grid x:Name="WifiPasswordOverlay"
              Grid.RowSpan="2"
              Visibility="Collapsed"
              Background="#E605080D"
              Panel.ZIndex="100">

            <Border Width="580"
                    Background="#111A23"
                    BorderBrush="#26394D"
                    BorderThickness="1"
                    CornerRadius="22"
                    Padding="30"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                <StackPanel>

                    <Grid>

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel>

                            <TextBlock Text="Подключение к Wi-Fi"
                                       Foreground="White"
                                       FontSize="28"
                                       FontWeight="Bold"/>

                            <TextBlock x:Name="WifiPasswordNetworkText"
                                       Text="Название сети"
                                       Foreground="#4CA9DD"
                                       FontSize="20"
                                       Margin="0,8,0,0"/>

                        </StackPanel>

                        <Button Grid.Column="1"
                                Width="48"
                                Height="48"
                                Content="×"
                                Foreground="#AEBCCC"
                                Background="#1B2A38"
                                BorderThickness="0"
                                FontSize="26"
                                Click="CancelWifiPasswordButton_Click"/>

                    </Grid>

                    <TextBlock Text="Введите пароль сети"
                               Foreground="#8295A8"
                               FontSize="16"
                               Margin="0,24,0,8"/>

                    <PasswordBox x:Name="WifiPasswordBox"
                                 Height="60"
                                 FontSize="22"
                                 Padding="16,0"
                                 VerticalContentAlignment="Center"
                                 Foreground="White"
                                 Background="#0B141D"
                                 BorderBrush="#2B4258"
                                 BorderThickness="1"/>

                    <TextBlock x:Name="WifiPasswordErrorText"
                               Text=""
                               Foreground="#E57373"
                               FontSize="15"
                               TextWrapping="Wrap"
                               Margin="0,10,0,0"/>

                    <Grid Margin="0,26,0,0">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="14"/>
                            <ColumnDefinition Width="190"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Content="Отмена"
                                Style="{StaticResource ActionButtonStyle}"
                                Background="#263746"
                                Click="CancelWifiPasswordButton_Click"/>

                        <Button Grid.Column="3"
                                Content="Подключиться"
                                Style="{StaticResource ActionButtonStyle}"
                                Click="ConnectWifiPasswordButton_Click"/>

                    </Grid>

                </StackPanel>

            </Border>

        </Grid>

    </Grid>

</UserControl>