<Window x:Class="Updater.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Обновление CarShell"
        Width="800"
        Height="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#05080D"
        Foreground="White">

    <Grid Margin="30">

        <Border Background="#101820"
                BorderBrush="#1B2A38"
                BorderThickness="1"
                CornerRadius="20"
                Padding="28">

            <StackPanel VerticalAlignment="Center">

                <TextBlock Text="Обновление CarShell"
                           FontSize="30"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"/>

                <ProgressBar Height="12"
                             Margin="0,30,0,22"
                             IsIndeterminate="True"/>

                <TextBlock x:Name="StatusText"
                           Text="Подготовка..."
                           FontSize="18"
                           Foreground="#B8C5D2"
                           TextAlignment="Center"
                           TextWrapping="Wrap"/>

            </StackPanel>

        </Border>

    </Grid>

</Window>